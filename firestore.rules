rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Path Variable & ID Poisoning checks
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Entity Schemas and Type/Length Validations
    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'rekanan', 'tanggalBayar', 'jumlahBayar', 'metodeBayar', 'catatan', 'tanggalDeadlineTagihan', 'status', 'hasInvoice'])
        && data.id is string && data.id.size() <= 128
        && data.rekanan is string && data.rekanan.size() <= 100
        && data.tanggalBayar is string && data.tanggalBayar.size() <= 50
        && data.jumlahBayar is number && data.jumlahBayar >= 0
        && data.metodeBayar is string && data.metodeBayar.size() <= 100
        && data.catatan is string && data.catatan.size() <= 1000
        && data.tanggalDeadlineTagihan is string && data.tanggalDeadlineTagihan.size() <= 50
        && (data.status == 'Draft' || data.status == 'Aktif')
        && data.hasInvoice is bool;
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['id', 'paymentId', 'rekanan', 'jumlahBayar', 'customerDebitur', 'nomorTagihan', 'tanggalTagihan', 'tanggalJatuhTempo', 'jumlahTagihKotor', 'ppnTarif', 'pphTarif', 'ppnNominal', 'pphNominal', 'totalTagihan', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.paymentId is string && data.paymentId.size() <= 128
        && data.rekanan is string && data.rekanan.size() <= 100
        && data.jumlahBayar is number && data.jumlahBayar >= 0
        && data.customerDebitur is string && data.customerDebitur.size() <= 100
        && data.nomorTagihan is string && data.nomorTagihan.size() <= 100
        && data.tanggalTagihan is string && data.tanggalTagihan.size() <= 50
        && data.tanggalJatuhTempo is string && data.tanggalJatuhTempo.size() <= 50
        && data.jumlahTagihKotor is number && data.jumlahTagihKotor >= 0
        && data.ppnTarif is number && data.ppnTarif >= 0
        && data.pphTarif is number && data.pphTarif >= 0
        && data.ppnNominal is number && data.ppnNominal >= 0
        && data.pphNominal is number && data.pphNominal >= 0
        && data.totalTagihan is number && data.totalTagihan >= 0
        && (data.status == 'Belum Lunas' || data.status == 'Lunas');
    }

    function isValidInvoiceLog(data) {
      return data.keys().hasAll(['id', 'invoiceId', 'tanggal', 'posisi', 'catatan', 'updatedBy'])
        && data.id is string && data.id.size() <= 128
        && data.invoiceId is string && data.invoiceId.size() <= 128
        && data.tanggal is string && data.tanggal.size() <= 50
        && data.posisi is string && data.posisi.size() <= 200
        && data.catatan is string && data.catatan.size() <= 1000
        && data.updatedBy is string && data.updatedBy.size() <= 100;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'judul', 'deskripsi', 'tanggal', 'tipe', 'read'])
        && data.id is string && data.id.size() <= 128
        && data.judul is string && data.judul.size() <= 200
        && data.deskripsi is string && data.deskripsi.size() <= 1000
        && data.tanggal is string && data.tanggal.size() <= 50
        && (data.tipe == 'deadline' || data.tipe == 'approval' || data.tipe == 'log' || data.tipe == 'system')
        && data.read is bool;
    }

    function isValidCompanySettings(data) {
      return data.keys().hasAll(['namaPerusahaan', 'alamat', 'npwp', 'ppnDefault', 'pphDefault', 'formatNomorTagihan', 'notifDeadlineH3', 'notifDeadlineH1'])
        && data.namaPerusahaan is string && data.namaPerusahaan.size() <= 200
        && data.alamat is string && data.alamat.size() <= 1000
        && data.npwp is string && data.npwp.size() <= 100
        && data.ppnDefault is number
        && data.pphDefault is number
        && data.formatNomorTagihan is string && data.formatNomorTagihan.size() <= 100
        && data.notifDeadlineH3 is bool
        && data.notifDeadlineH1 is bool;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nama', 'username', 'role'])
        && data.id is string && data.id.size() <= 128
        && data.nama is string && data.nama.size() <= 100
        && data.username is string && data.username.size() <= 50
        && (data.role == 'SUPERVISOR_KEUANGAN_UMUM' || data.role == 'STAF_ADMINISTRASI_UMUM' || data.role == 'DIREKTUR' || data.role == 'ADMINISTRATOR');
    }

    function isValidDailyCashBalance(data) {
      return data.keys().hasAll(['id', 'tanggal', 'balances'])
        && data.id is string && data.id.size() <= 128
        && data.tanggal is string && data.tanggal.size() <= 50
        && data.balances is map;
    }

    // Collection Level Access Controls
    match /payments/{paymentId} {
      allow read: if true;
      allow create: if isValidId(paymentId) && isValidPayment(request.resource.data);
      allow update: if isValidId(paymentId) && isValidPayment(request.resource.data);
      allow delete: if isValidId(paymentId);
    }

    match /invoices/{invoiceId} {
      allow read: if true;
      allow create: if isValidId(invoiceId) && isValidInvoice(request.resource.data);
      allow update: if isValidId(invoiceId) && isValidInvoice(request.resource.data);
      allow delete: if isValidId(invoiceId);
    }

    match /logs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) && isValidInvoiceLog(request.resource.data);
      allow update: if isValidId(logId) && isValidInvoiceLog(request.resource.data);
      allow delete: if isValidId(logId);
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow create: if isValidId(notifId) && isValidNotification(request.resource.data);
      allow update: if isValidId(notifId) && isValidNotification(request.resource.data);
      allow delete: if isValidId(notifId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isValidId(settingId) && isValidCompanySettings(request.resource.data);
      allow update: if isValidId(settingId) && isValidCompanySettings(request.resource.data);
      allow delete: if isValidId(settingId);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if isValidId(userId);
    }

    match /cashBalances/{balanceId} {
      allow read: if true;
      allow create: if isValidId(balanceId) && isValidDailyCashBalance(request.resource.data);
      allow update: if isValidId(balanceId) && isValidDailyCashBalance(request.resource.data);
      allow delete: if isValidId(balanceId);
    }
  }
}
